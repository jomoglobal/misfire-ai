# OpenAI (GPT-4o) — diagnostic agent
OPENAI_API_KEY=your_openai_key_here

# Phoenix / Arize — personal account (get at app.phoenix.arize.com)
PHOENIX_COLLECTOR_ENDPOINT_PERSONAL=https://app.phoenix.arize.com/s/YOUR_USERNAME/v1/traces
PHOENIX_API_KEY_PERSONAL=your_personal_phoenix_key
PHOENIX_PROJECT_NAME_PERSONAL=MisfireAI

# Phoenix / Arize — instructor account (Sravan / Euler)
PHOENIX_COLLECTOR_ENDPOINT_SRAVAN=https://app.phoenix.arize.com/s/euler/v1/traces
PHOENIX_API_KEY_SRAVAN=your_sravan_key
PHOENIX_PROJECT_NAME_SRAVAN=MisfireAI-Evals

# Kaggle — only needed for downloading external datasets
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_kaggle_key

# SendGrid — transactional email (HITL approval flow)
# Get at sendgrid.com — free tier is 100 emails/day
SENDGRID_API_KEY=SG.your_key_here
HITL_FROM_EMAIL=misfire@yourdomain.com
HITL_CALLBACK_HOST=http://localhost
HITL_CALLBACK_PORT=8741

# Telegram (future — HITL channel 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
